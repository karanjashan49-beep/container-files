Instrustions to build a file to build a image for a container in which we will run a website.

1  FROM amazonlinux:latest
2  RUN yum install httpd zip unzip -y
3  WORKDIR /var/www/html
4  ADD https://templated.live/hielo/download/hielo.zip /var/www/html
5  RUN unzip hielo.zip && rm -f hielo.zip
6  EXPOSE 80
7  CMD ["/usr/sbin/httpd", "-D", "FOREGROUND"]   

